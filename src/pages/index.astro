---
import Card from '../components/Card.astro';
import Layout from '../layouts/Layout.astro';
const data = [
  {
    title: 'App y plataforma',
    description:
      'En el mundo de la atención médica actual, la precisión es esencial para brindar el mejor cuidado a nuestros pacientes. Con la ayuda de la inteligencia artificial y la innovación en dispositivos de última generación, estamos liderando el camino hacia una atención cardiológica más avanzada y personalizada que nunca.',
  },
  {
    title: 'Nuestra Tecnología de Vanguardia',
    description:
      'Utilizamos dispositivos propios diseñados específicamente para medir su salud cardiovascular de manera precisa y continua. Estos dispositivos incluyen ECGs, holters, parches, implantables y wearables. Nuestra tecnología no solo registra los datos, sino que también utiliza algoritmos de inteligencia artificial de última generación para analizarlos de manera rápida y eficiente.',
  },
];
---

<Layout>
  <h1 class="text-4xl md:text-5xl lg:text-6xl text-center mb-5">
    Detección y medicina de precisión con IA para cardiología
  </h1>
  <h2 class="text-l md:text-xl lg:text-2xl text-center px-5 mb-5">
    Llevar el poder de la inteligencia artificial a la atención cardiaca
  </h2>
  <div class="flex flex-col md:flex-row">
    {data.map((d) => <Card title={d.title} description={d.description} />)}
  </div>
</Layout>
