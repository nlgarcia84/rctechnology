---
import Button from './Button.astro';
import { Picture } from 'astro:assets';
import logo from '../assets/rctlogo.png';
import logoMobile from '../assets/rctlogo_mobile.png';
---

<header
  class="flex items-center justify-between mb-5 px-4 py-3 sm:px-10 sm:py-5 md:py-6 rounded-2xl bg-gray-900/80 backdrop-blur-md text-white"
>
  <!-- Logo Mobile -->
  <a href="/" class="logo shrink-0 md:hidden h-12">
    <Picture
      src={logoMobile}
      alt="RC Technology"
      width={48}
      height={48}
      formats={['webp', 'png']}
    />
  </a>

  <!-- Logo Desktop -->
  <a href="/" class="logo shrink-0 hidden md:block h-24">
    <Picture
      src={logo}
      alt="RC Technology"
      width={96}
      height={96}
      formats={['webp', 'png']}
    />
  </a>

  <!-- Desktop Nav -->
  <nav class="hidden md:flex gap-6 lg:gap-8">
    <a href="#" class="hover:text-blue-400 transition">Inicio</a>
    <a href="#" class="hover:text-blue-400 transition">Acerca de</a>
    <a href="#form" class="hover:text-blue-400 transition">Contacto</a>
  </nav>

  <div class="flex gap-4 items-center">
    <!-- Botones -->
    <Button
      as="a"
      href="http://54.37.38.27/"
      id="redbeatbutton"
      class="border border-red-700 px-5 py-3 rounded-2xl hidden md:block"
      text="REDBEAT"
    />
    <Button
      as="a"
      href="#form"
      class="bg-red-700 px-5 py-3 rounded-2xl"
      text="Contactanos"
    />

    <!-- Botón menú móvil -->
    <button
      id="menu-btn"
      class="md:hidden relative w-8 h-8 flex flex-col justify-around"
      aria-label="Menú"
    >
      <span class="block w-full h-0.5 bg-white transition-all duration-300"
      ></span>
      <span class="block w-full h-0.5 bg-white transition-all duration-300"
      ></span>
      <span class="block w-full h-0.5 bg-white transition-all duration-300"
      ></span>
    </button>
  </div>
</header>

<!-- Mobile Menu -->
<nav
  id="mobile-menu"
  class="md:hidden fixed top-0 left-0 h-full w-4/5 max-w-xs bg-gray-900/60 backdrop-blur-lg rounded-xl text-white z-50 transform -translate-x-full transition-transform duration-300 ease-in-out shadow-lg p-5 text-3xl"
>
  <!-- enlaces aquí -->
  <a href="#" class="block px-6 py-4 hover:bg-gray-700">Inicio</a>
  <a href="#" class="block px-6 py-4 hover:bg-gray-700">Acerca de</a>
  <a
    href="http://54.37.38.27/"
    class="block px-6 py-4 hover:bg-gray-700"
    target="_blank"
    rel="noopener noreferrer"
  >
    Plataforma
  </a>
  <nav
    id="mobile-menu"
    class="md:hidden fixed top-0 left-0 h-full w-4/5 max-w-xs bg-white/20 backdrop-blur-lg rounded-xl border border-white/30 text-white z-50 transform -translate-x-full transition-transform duration-300 ease-in-out shadow-lg"
  >
  </nav>

  <style>
    .logo img {
      transition: opacity 0.3s;
    }

    .logo:hover img {
      opacity: 0.8;
    }

    #menu-btn span {
      transform-origin: center;
    }

    #menu-btn.active span:nth-child(1) {
      transform: rotate(45deg) translate(8px, 8px);
    }

    #menu-btn.active span:nth-child(2) {
      opacity: 0;
    }

    #menu-btn.active span:nth-child(3) {
      transform: rotate(-45deg) translate(7px, -6px);
    }
  </style>

  <script>
    const menuBtn = document.getElementById(
      'menu-btn',
    ) as HTMLButtonElement | null;

    const mobileMenu = document.getElementById(
      'mobile-menu',
    ) as HTMLElement | null;

    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        menuBtn.classList.toggle('active');
        mobileMenu.classList.toggle('-translate-x-full');
      });

      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          menuBtn.classList.remove('active');
          mobileMenu.classList.add('-translate-x-full');
        });
      });
    }
  </script>
</nav>
