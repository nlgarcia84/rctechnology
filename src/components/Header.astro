---
import Button from './Button.astro';
import { Picture } from 'astro:assets';
import logo from '../assets/rctlogo.png';
import logoMobile from '../assets/rctlogo_mobile.png';
---

<header
  class="flex items-center justify-between mb-5 px-4 py-3 sm:px-10 sm:py-5 md:py-6 rounded-2xl bg-gray-900/80 backdrop-blur-md text-white"
>
  <a href="/" class="logo shrink-0 md:hidden h-12">
    <Picture
      src={logoMobile}
      alt="RC Technology"
      width={48}
      height={48}
      formats={['webp', 'png']}
    />
  </a>

  <a href="/" class="logo shrink-0 hidden md:block h-24">
    <Picture
      src={logo}
      alt="RC Technology"
      width={96}
      height={96}
      formats={['webp', 'png']}
    />
  </a>

  <!-- Desktop Nav -->
  <nav class="hidden md:flex gap-6 lg:gap-8">
    <a href="" class="hover:text-blue-400 transition">Inicio</a>
    <a href="" class="hover:text-blue-400 transition">Acerca de</a>
    <a href="" class="hover:text-blue-400 transition">Contacto</a>
    <a href="" class="hover:text-blue-400 transition">Plataforma</a>
  </nav>

  <div class="flex gap-4 items-center">
    <!-- CTA Form -->
    <Button
      id="redbeatbutton"
      class="border border-red-700 px-5 py-3 rounded-2xl hidden md:block"
      text="REDBEAT"
    />
    <Button class="bg-red-700 px-5 py-3 rounded-2xl" text="Contactanos" />

    <!-- Mobile Menu Button -->
    <button
      class="md:hidden relative w-8 h-8 flex flex-col justify-around"
      id="menu-btn"
      aria-label="Menú"
    >
      <span class="block w-full h-0.5 bg-white transition-all duration-300"
      ></span>
      <span class="block w-full h-0.5 bg-white transition-all duration-300"
      ></span>
      <span class="block w-full h-0.5 bg-white transition-all duration-300"
      ></span>
    </button>
  </div>
</header>

<!-- Mobile Nav -->
<nav
  id="mobile-menu"
  class="md:hidden hidden bg-gray-800 text-white max-h-0 overflow-hidden transition-all duration-300"
>
  <a href="" class="block px-4 py-3 hover:bg-gray-700 transition">Inicio</a>
  <a href="" class="block px-4 py-3 hover:bg-gray-700 transition">Acerca de</a>
  <a href="" class="block px-4 py-3 hover:bg-gray-700 transition">Contacto</a>
  <a href="" class="block px-4 py-3 hover:bg-gray-700 transition">Plataforma</a>
</nav>

<style>
  .logo img {
    transition: opacity 0.3s;
  }

  .logo:hover img {
    opacity: 0.8;
  }

  #menu-btn span {
    transform-origin: center;
  }

  #menu-btn.active span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
  }

  #menu-btn.active span:nth-child(2) {
    opacity: 0;
  }

  #menu-btn.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -6px);
  }

  #mobile-menu.open {
    max-height: 200px;
  }
</style>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      menuBtn.classList.toggle('active');
      mobileMenu.classList.toggle('open');
    });

    // Cerrar menu al clickear un link
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menuBtn.classList.remove('active');
        mobileMenu.classList.remove('open');
      });
    });
  }
</script>
