---
interface Props {
  title: string;
  description: string;
  icon?: string;
  link?: string;
  class?: string;
}

const {
  title,
  description,
  icon,
  link = '#',
  class: className = '',
} = Astro.props;
---

<a href={link} class={`group block md:max-w-sm`}>
  <div
    class={`m-4 h-full rounded-lg border border-gray-700 bg-gray-900/50 backdrop-blur-sm p-6 transition-all duration-300 hover:border-gray-600 hover:bg-gray-900/80 hover:shadow-lg hover:shadow-red-500/10 ${className}`}
  >
    {icon && <div class="mb-4 text-3xl">{icon}</div>}

    <h3
      class="mb-2 text-xl font-bold text-white group-hover:text-red-500 transition"
    >
      {title}
    </h3>

    <p class="text-gray-400 text-sm leading-relaxed">
      {description}
    </p>

    <div
      class="mt-4 flex items-center gap-2 text-red-500 opacity-0 group-hover:opacity-100 transition"
    >
      <span class="text-sm font-medium">Conocer más</span>
      <span>→</span>
    </div>
  </div>
</a>

<style>
  a {
    text-decoration: none;
  }
</style>
